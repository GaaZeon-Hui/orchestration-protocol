一张总的状态表，用数字格子控制权限：只有上游步骤完成后，下游才能获得写入权限。

-- 单张流水线状态表（类似 CPU 的指令周期）
CREATE TABLE pipeline_state (
    request_id TEXT PRIMARY KEY,
    agent_name TEXT NOT NULL,
    
    -- 每个步骤的完成标志（1=已完成，0=未完成）
    step1_acquire_lock INTEGER DEFAULT 0,
    step2_scan_requests INTEGER DEFAULT 0,
    step3_conflict_analysis INTEGER DEFAULT 0,
    step4_boundary_analysis INTEGER DEFAULT 0,
    step5_logic_analysis INTEGER DEFAULT 0,
    step6_write_approval INTEGER DEFAULT 0,
    step7_issue_lock INTEGER DEFAULT 0,
    step8_release_lock INTEGER DEFAULT 0,
    
    -- 控制字段
    current_step INTEGER DEFAULT 1,     -- 当前允许执行的步骤
    status TEXT DEFAULT 'pending',      -- pending/active/completed/failed
    error_message TEXT,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    
    -- 并发控制
    version INTEGER DEFAULT 1           -- 乐观锁版本号
);

-- 索引
CREATE INDEX idx_pipeline_status ON pipeline_state(status, current_step);



