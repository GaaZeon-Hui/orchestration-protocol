按顺序递增步骤
-- 触发器：确保步骤只能按顺序完成
CREATE TRIGGER enforce_step_order_before_update
BEFORE UPDATE ON pipeline_state
BEGIN
    -- 检查是否试图跳过步骤
    SELECT CASE
        WHEN NEW.step2_scan_requests = 1 AND OLD.step1_acquire_lock = 0
        THEN RAISE(ABORT, 'Cannot complete step2 before step1')
        
        WHEN NEW.step3_conflict_analysis = 1 AND OLD.step2_scan_requests = 0
        THEN RAISE(ABORT, 'Cannot complete step3 before step2')
        
        WHEN NEW.step4_boundary_analysis = 1 AND OLD.step3_conflict_analysis = 0
        THEN RAISE(ABORT, 'Cannot complete step4 before step3')
        
        WHEN NEW.step5_logic_analysis = 1 AND OLD.step4_boundary_analysis = 0
        THEN RAISE(ABORT, 'Cannot complete step5 before step4')
        
        WHEN NEW.step6_write_approval = 1 AND OLD.step5_logic_analysis = 0
        THEN RAISE(ABORT, 'Cannot complete step6 before step5')
        
        WHEN NEW.step7_issue_lock = 1 AND OLD.step6_write_approval = 0
        THEN RAISE(ABORT, 'Cannot complete step7 before step6')
        
        WHEN NEW.step8_release_lock = 1 AND OLD.step7_issue_lock = 0
        THEN RAISE(ABORT, 'Cannot complete step8 before step7')
    END;
    
    -- 自动更新 current_step 和 updated_at
    SET NEW.current_step = (
        CASE 
            WHEN NEW.step1_acquire_lock = 0 THEN 1
            WHEN NEW.step2_scan_requests = 0 THEN 2
            WHEN NEW.step3_conflict_analysis = 0 THEN 3
            WHEN NEW.step4_boundary_analysis = 0 THEN 4
            WHEN NEW.step5_logic_analysis = 0 THEN 5
            WHEN NEW.step6_write_approval = 0 THEN 6
            WHEN NEW.step7_issue_lock = 0 THEN 7
            WHEN NEW.step8_release_lock = 0 THEN 8
            ELSE 9  -- 全部完成
        END
    );
    
    SET NEW.updated_at = CURRENT_TIMESTAMP;
    
    -- 如果所有步骤完成，更新状态
    UPDATE pipeline_state 
    SET status = 'completed' 
    WHERE request_id = NEW.request_id 
      AND NEW.step8_release_lock = 1;
END;

